    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "knip": "^6.16.1",
    "playwright-core": "1.56.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^7.3.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8"
