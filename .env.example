# HubPlay — environment overrides
#
# Copy this file to `.env` to customise. Everything has sensible defaults,
# so the stack runs plug-and-play with `docker compose up -d` even without it.

# Host port the UI is exposed on (container always listens on 8096 internally).
HUBPLAY_HOST_PORT=8097

# Host paths for your media libraries.
# Defaults are `./peliculas` and `./series` next to this compose file,
# which is what the demo ships with. Point them anywhere on your host:
#
#   Windows (Docker Desktop):
#     HUBPLAY_MEDIA_MOVIES=D:/Media/Movies
#     HUBPLAY_MEDIA_SERIES=D:/Media/Series
#
#   Linux/macOS:
#     HUBPLAY_MEDIA_MOVIES=/mnt/nas/movies
#     HUBPLAY_MEDIA_SERIES=/mnt/nas/series
HUBPLAY_MEDIA_MOVIES=./peliculas
HUBPLAY_MEDIA_SERIES=./series

# IANA timezone (e.g. UTC, America/New_York, Asia/Tokyo).
TZ=Europe/Madrid

# Bundled PostgreSQL password. The `db` service in docker-compose.yml
# ships a Postgres alongside hubplay so the admin panel can offer a
# one-click "Switch to PostgreSQL" toggle without making you type a
# DSN. Default `hubplay` is fine for the typical home server: the DB
# is on an internal docker network, not exposed to the host. Override
# only if you want extra paranoia or if you'll expose the DB port.
HUBPLAY_POSTGRES_PASSWORD=hubplay
