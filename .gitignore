bin/
/hubplay
*.db
*.db-wal
*.db-shm
coverage.out
coverage.html
.env
/config/

# Frontend
web/node_modules/

# Foreign JS lockfiles. El proyecto usa pnpm (web/package.json declara
# packageManager: pnpm@…); si alguien hace `npm install` por accidente
# y genera un package-lock.json, no debe commitearse.
web/package-lock.json
web/yarn.lock

# Vite build output. The directory is tracked (via web/dist/.gitkeep) so
# the `go:embed all:web/dist` directive in migrations.go compiles on a
# fresh clone. Only build artifacts are ignored; rebuild with
# `pnpm build` or `make web` to regenerate.
web/dist/*
!web/dist/.gitkeep


/peliculas
/series

# Runtime cache (VOD transcode segments, IPTV HLS transmux work dirs).
# Created by docker-compose volume mount; never tracked.
/cache/

# pnpm local store materialised when CI / Docker runs `pnpm install`
# inside the repo with no shared global store.
web/.pnpm-store/
_backups/

# sqlc drift test scratch (internal/db/sqlc_drift_test.go)
.sqlc-drift-*
